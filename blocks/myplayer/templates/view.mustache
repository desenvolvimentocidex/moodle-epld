<div class="player-container">
    <div class="player-content">
        {{#menu}}
            <div class="player-mb-15">
                <form action="{{formaction}}" method="post">
                    <input type="hidden" name="userid" value="{{userid}}" />
                    <input type="hidden" name="userrole" value="{{userrole}}" />
                    <input type="hidden" name="courseid" value="{{courseid}}" />

                    <label for="audio">Áudio:</label>
                    <input type="file" id="audio" name="audio">

                    <input type="submit" value="Enviar" />
                </form>
            </div>
        {{/menu}}

        <audio controls>
            <source src="{{audio}}" type="audio/wav">
            Your browser does not support the audio element.
        </audio>
    </div>
</div>

{{#js}}
    var config = {
        totalDisabled: '2',
        url: {
            courseViewURL: fnGetProtocol() + '//' + fnGetHost() + '/course/view.php',
            modQuizAttemptURL: fnGetProtocol() + '//' + fnGetHost() + '/mod/quiz/attempt.php',
            questionBankPreviewQuestionPreview: fnGetProtocol() + '//' + fnGetHost() + '/question/bank/previewquestion/preview.php'
        },
        buttons: {
            retornarProva: {
                display: 'none' //block or none
            },
            voltar: {
                display: 'none' //block or none
            },
            finalizarProva: {
                display: 'none' //block or none
            }
        }
    }

    fnSetHTML(config);

    var audio = document.querySelector('audio');

    if (audio) {
        audio.removeAttribute('controls');
        audio.addEventListener('play', fnPlayEvent, false);
        audio.addEventListener('timeupdate', fnUpdateEvent, false);
    }

    var btnPlay = document.getElementById("btnPlay");

    var courseViewURL = fnMoodleURLs('course/view');
    console.log(courseViewURL);
    console.log(config.url.courseViewURL);

    var modQuizAttemptURL = fnMoodleURLs('mod/quiz/attempt');
    //console.log(modQuizAttemptURL);
    //console.log(config.url.modQuizAttemptURL);

    var questionBankPreviewQuestionPreview = fnMoodleURLs('question/bank/previewquestion/preview');
    //console.log(questionBankPreviewQuestionPreview);
    //console.log(config.url.questionBankPreviewQuestionPreview);

    //Na Capa de Prova, o player deverá ser executado quantas vezes for necessário
    if (
        (courseViewURL == config.url.courseViewURL) ||
        (questionBankPreviewQuestionPreview == config.url.questionBankPreviewQuestionPreview)
    ) {
        btnPlay.onclick = function(e) {
            e.preventDefault();
            audio.play();
        }
    }

    if (modQuizAttemptURL == config.url.modQuizAttemptURL) {
        var controlMDL = fnSessionStorage('get', 'controlMDL');
        var count = document.querySelector('.count');

        fnSetContext();

        btnPlay.onclick = function(e) {
            e.preventDefault();

            sessionStorage.setItem('resetCountMDL', false);
        
            fnSessionStorage('set');
        
            audio.play();
        
            var total = parseInt(count.textContent) + 1;
            count.textContent = total;
        
            sessionStorage.setItem('countMDL', total);
        
            if (total == 1) {
                this.setAttribute('disabled', controlMDL);
                this.style.backgroundColor = '#cccccc';
                sessionStorage.setItem('resetCountMDL', false);
            }

            if (total == config.totalDisabled) {
                this.setAttribute('disabled', controlMDL);
                this.style.backgroundColor = '#cccccc';
                sessionStorage.setItem('resetCountMDL', true);
            }
        }
    }

    document.addEventListener("DOMContentLoaded", function(event) {
        sessionStorage.setItem('finishMDL', false);

        //Botão - Próxima página
        /*var btnNextPageMDL = document.getElementsByName("next");

        if (btnNextPageMDL) {
            for (let i = 0; i < btnNextPageMDL.length; i++) {
                console.log(btnNextPageMDL[i].getAttribute("value"));
                console.log(btnNextPageMDL[i].getAttribute("id"));
            
                if (btnNextPageMDL[i].getAttribute("value") == 'Próxima página') {
                    btnNextPageMDL[i].onclick = function(e) {
                        e.preventDefault();
                        console.log("Sucesso: entrou aqui!");
                        
