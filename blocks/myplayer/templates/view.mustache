                        sessionStorage.setItem('countMDL', 0);
                        sessionStorage.setItem('resetCountMDL', false);
                        sessionStorage.setItem('urlMDL', urlNOW);
                        sessionStorage.setItem('controlMDL', false);
                    }
                }
            }
        }*/

        //Botão - Finalizar prova ...
        var btnFinishMDL = document.body.getElementsByTagName("a");
        
        for (let i = 0; i < btnFinishMDL.length; i++) {
            //console.log(btnFinishMDL[i].textContent);                
            //console.log(btnFinishMDL[i].innerText);                
            //console.log(btnFinishMDL[i].text);

            if (btnFinishMDL[i].textContent == 'Finalizar prova ...') {
                //console.log(btnFinishMDL[i].textContent);
                //console.log(btnFinishMDL[i].getAttribute("href"));
                btnFinishMDL[i].style.display = config.buttons.finalizarProva.display;
                
