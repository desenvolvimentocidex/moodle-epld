    function stopDefAction(evt) {
        evt.preventDefault();
    }

    //Próxima página
    var btnNextMoodle = document.getElementById("mod_quiz-next-nav");
    if (btnNextMoodle) {
        btnNextMoodle.addEventListener("click", fnNextMoodle);
    }

    //Enviar tudo e terminar
    var btnSendFinishMoodle = document.querySelector(".submitbtns > .controls > .btn-finishattempt > #frm-finishattempt > button");
    if (btnSendFinishMoodle) {
        btnSendFinishMoodle.addEventListener("click", fnSendFinishMoodle);
    }

    //Função criada para resolver o bug de não bloquear a execução do player quando executado 2 vezes ao retornar a prova
    setInterval(refresh, 1000);

    function refresh() {
        var btnPlay = document.getElementById("btnPlay");
        var count = document.querySelector('.count');

        if (btnPlay && count) {
            var countMDL = fnSessionStorage('get', 'countMDL');
            var controlMDL = fnSessionStorage('get', 'controlMDL');
            var resetCountMDL = sessionStorage.getItem('resetCountMDL');

            count.textContent = countMDL;

            var time = fnSecToString(audio.currentTime);
            var timeTotal = fnSecToString(audio.duration);

            if ((countMDL == '1') && (time != '00:00:00' && timeTotal != '00:00:00') && (time == timeTotal)) {
                btnPlay.removeAttribute('disabled');
                btnPlay.style.backgroundColor = '#0f6cbf';
            }
        
            if ((countMDL == '2') && (resetCountMDL == 'true')) {
                btnPlay.setAttribute('disabled', controlMDL);
            } 
            
            if ((countMDL == '2') && (resetCountMDL == 'false')) {
                count.textContent = 0;
                btnPlay.removeAttribute('disabled');
                btnPlay.style.backgroundColor = '#0f6cbf';
            }
        }
    }

    refresh();

    function fnNextMoodle() {
        var urlNOW = fnGetURL();

        var finishMDL = sessionStorage.getItem('finishMDL');

        if (finishMDL == 'false') {
            sessionStorage.setItem('countMDL', 0);
            sessionStorage.setItem('resetCountMDL', false);
            sessionStorage.setItem('urlMDL', urlNOW);
            sessionStorage.setItem('controlMDL', false);
        }
    }

    function fnSendFinishMoodle() {
        var urlNOW = fnGetURL();

        sessionStorage.setItem('countMDL', 0);
        sessionStorage.setItem('resetCountMDL', false);
        sessionStorage.setItem('urlMDL', urlNOW);
        sessionStorage.setItem('controlMDL', false);
    }

    function fnSetHTML(config) {
        var html = '';
        var courseViewURL = fnMoodleURLs('course/view');
        var questionBankPreviewQuestionPreview = fnMoodleURLs('question/bank/previewquestion/preview');

        html += '<div class="player-container">';
            html += '<div class="player-content">';
                html += '<div class="player-content-item">';
                    html += '<div class="player-timer">';
                        html += '<span id="time">00:00:00</span> / <span id="timeTotal">00:00:00</span>';
                    html += '</div>';

                    html += '&nbsp;&nbsp;';

                    html += '<button id="btnPlay" class="player-btn-play">';
                        html += '<i class="fa fa-play"></i>';
                    html += '</button>';
                html += '</div>';

                html += '<progress id="progressBar" max="0" value="0" class="player-progressbar"></progress>';
                
                html += '<div class="player-counter">';
                    html += 'Executado <span class="count">0</span> vez(es)';
                html += '</div>';
            html += '</div>';
        html += '</div>';

        var div = document.createElement('div');
        div.innerHTML = html;
        
        var audio = document.querySelector('audio');

        if (audio) {
            audio.parentElement.insertBefore(div.firstChild, audio);
        }
    }

    function fnSetContext() {
        var btnPlay = document.getElementById("btnPlay");
        var count = document.querySelector('.count');
        
        if (count && btnPlay) {
            var urlNOW = fnGetURL();
            var countMDL = fnSessionStorage('get', 'countMDL');
            var urlMDL = fnSessionStorage('get', 'urlMDL');
            var controlMDL = fnSessionStorage('get', 'controlMDL');
        
            if (!countMDL || (countMDL == '0')) {
                sessionStorage.setItem('countMDL', 0);
            }
        
            sessionStorage.setItem('urlMDL', urlNOW);

            var resetCountMDL = sessionStorage.getItem('resetCountMDL');

            if ((controlMDL == 'true') && (countMDL == '1')) {
                count.textContent = countMDL;
            } else if ((controlMDL == 'true') && (countMDL == '2') && (resetCountMDL == 'true')) {
                btnPlay.setAttribute('disabled', controlMDL);
                count.textContent = countMDL;
            } else if ((controlMDL == 'true') && (countMDL == '2') && (resetCountMDL == 'false')) {
                btnPlay.removeAttribute('disabled');
                count.textContent = 0;
            }
        }
    }

    function fnPlayEvent() {
        document.getElementById('time').innerHTML = fnSecToString(audio.currentTime);
        document.getElementById('timeTotal').innerHTML = fnSecToString(audio.duration);
        document.getElementById('progressBar').max = audio.duration;
        document.getElementById('progressBar').value = audio.currentTime;
    }

    function fnUpdateEvent() {
        document.getElementById('time').innerHTML = fnSecToString(audio.currentTime);
        document.getElementById('progressBar').value = audio.currentTime;
    }

    function fnSecToString(secNum) {
        secNum = Math.floor(secNum);

        var time = Math.floor(secNum / 3600);
        var min = Math.floor((secNum - (time * 3600)) / 60);
        var seg = secNum - (time * 3600) - (min * 60);

        if (time < 10) {
            time = "0" + time;
        }

        if (min < 10) {
            min = "0" + min;
        }

        if (seg < 10) {
            seg = "0" + seg;
        }

        var result = time + ':' + min + ':' + seg;

        return result;
    }

    function fnGetURL() {
        var url = window.location.href;
        return url;
    }

    function fnGetHost() {
        var host = window.location.host;
        return host;
    }

    function fnGetHostname() {
        var hostname = window.location.hostname;
        return hostname;
    }

    function fnGetProtocol() {
        var protocol = window.location.protocol;
        return protocol;
    }

    function fnMoodleURLs(str) {
        var protocol = fnGetProtocol();
        var url = fnGetURL();

        var result = '';

        switch (str) {
            case 'course/view': 
                //result = url.substring(0, 41); //http://cidexepl.eb.mil.br/course/view.php?id=
                result = url.substring(0, 32); //http://localhost/course/view.php?id=
                break;
            case 'mod/quiz/attempt': //http://cidexepl.eb.mil.br/mod/quiz/attempt.php
                result = url.substring(0, 46);
                break;
            case 'question/bank/previewquestion/preview': //http://cidexepl.eb.mil.br/question/bank/previewquestion/preview.php
                result = url.substring(0, 67);
                break;
        }

        return result;
    }

    function fnSessionStorage(type, element) {
        var url = fnGetURL();

        if (type == 'set') {
            sessionStorage.setItem('urlMDL', url);
            sessionStorage.setItem('controlMDL', true);
        }

        if (type == 'get') {
            var result = '';

            if (element == 'countMDL') {
                result = sessionStorage.getItem('countMDL');
            }

            if (element == 'urlMDL') {
                result = sessionStorage.getItem('urlMDL');
            }

            if (element == 'controlMDL') {
                result = sessionStorage.getItem('controlMDL');
            }

            return result;
        }
    }
{{/js}}